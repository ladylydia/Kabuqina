{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kabuqina",
  "version": "0.1.0",
  "identifier": "com.kabuqina.app",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "cwd": "../web",
      "script": "npm run dev"
    },
    "beforeBuildCommand": {
      "cwd": "../web",
      "script": "npm ci && npm run build"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "卡布奇娜",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false,
        "center": true,
        "resizable": true,
        "visible": false,
        "dragDropEnabled": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: data: blob: http://127.0.0.1:* https:; connect-src ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:* https://api.openrouter.ai https://openrouter.ai https://api.openai.com https://api.anthropic.com https://portal.nousresearch.com https://api.groq.com https://api.mistral.ai https://api.deepseek.com https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/Kabuqina/**",
          "$LOCALDATA/Kabuqina/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Kabuqina Contributors",
    "category": "Productivity",
    "shortDescription": "Kabuqina, a friendly AI helper for your PC",
    "longDescription": "Kabuqina is a safe, easy-to-use AI assistant for Windows powered by the open-source Hermes Agent.",
    "copyright": "MIT licensed; see LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../python/dist/runtime": "runtime"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": ["en-US"],
        "template": "wix/main.wxs"
      },
      "allowDowngrades": false,
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.sectigo.com"
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/Kabuqina/Kabuqina/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  }
}
